rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Products images folder - allow authenticated users to upload, everyone can read
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}


