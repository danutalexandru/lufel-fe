# Copy to .env and fill in your values. Do not commit .env.

# Firebase (from Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Stripe (from Stripe Dashboard → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=

# Backend – use ONE of these (no # at the start of the line you use):
# Option A: Base URL
# VITE_BACKEND_URL=https://us-central1-PROJECT.cloudfunctions.net
# Option B: Full URL to createPaymentLink (recommended if you have a Cloud Run URL)
VITE_CREATE_PAYMENT_LINK_URL=https://createpaymentlink-42gclscyoq-uc.a.run.app
