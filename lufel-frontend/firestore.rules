rules_version = '2';
// Firestore Security Rules - deploy via Firebase Console (Rules tab) or: firebase deploy --only firestore
// See: https://firebase.google.com/docs/firestore/security/get-started
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: true if the current user has ADMIN role (user document must exist)
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'ADMIN';
    }

    // Products: anyone can read; only admins can create, update, delete
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: anyone can create (guest checkout); users can read own orders; guests can read guest orders (by link); admins can read/update/delete all
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || resource.data.userId == null;
      allow update, delete: if isAdmin();
    }

    // Users: users can only read/write their own document; role cannot be changed by client
    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.get('role', 'CUSTOMER'));
    }
  }
}

